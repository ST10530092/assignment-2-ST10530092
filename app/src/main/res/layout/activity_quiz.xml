<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:id="@+id/main" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#EEF3FB" tools:context=".Quiz">

    <View android:id="@+id/topBar" android:layout_width="0dp" android:layout_height="52dp" android:background="#D6E4F7" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>

    <TextView android:id="@+id/questionCountTxt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Question 1 of 7" android:textColor="#1A56DB" android:textSize="15sp" app:layout_constraintBottom_toBottomOf="@id/topBar" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="@id/topBar"/>

    <LinearLayout android:id="@+id/progressDots" android:layout_width="wrap_content" android:layout_height="14dp" android:layout_marginTop="20dp" android:gravity="center_vertical" android:orientation="horizontal" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/topBar">

        <View android:id="@+id/dot1" android:layout_width="12dp" android:layout_height="12dp" android:layout_marginEnd="6dp" android:background="@drawable/dot_active"/>

        <View android:layout_width="10dp" android:layout_height="10dp" android:layout_marginEnd="6dp" android:background="@drawable/dot_inactive"/>

        <View android:layout_width="10dp" android:layout_height="10dp" android:layout_marginEnd="6dp" android:background="@drawable/dot_inactive"/>

        <View android:layout_width="10dp" android:layout_height="10dp" android:layout_marginEnd="6dp" android:background="@drawable/dot_inactive"/>

        <View android:layout_width="10dp" android:layout_height="10dp" android:layout_marginEnd="6dp" android:background="@drawable/dot_inactive"/>

        <View android:layout_width="10dp" android:layout_height="10dp" android:layout_marginEnd="6dp" android:background="@drawable/dot_inactive"/>

        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/dot_inactive"/>
    </LinearLayout>

    <TextView android:id="@+id/titleTxt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Hack or Myth" android:textColor="#1A56DB" android:textSize="26sp" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/progressDots"/>

    <androidx.cardview.widget.CardView android:id="@+id/questionCard" android:layout_width="0dp" android:layout_height="160dp" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="20dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/titleTxt">
        <TextView android:id="@+id/questionTxt" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:padding="20dp" android:text="Question goes here" android:textAlignment="center" android:textColor="#6B7C93" android:textSize="16sp" android:lineSpacingExtra="3dp"/>
    </androidx.cardview.widget.CardView>

    <TextView android:id="@+id/feedbackTxt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:textColor="#1A56DB" android:textSize="16sp" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/questionCard" tools:text="Correct!"/>

    <Button android:id="@+id/hackBtn" android:layout_width="0dp" android:layout_height="56dp" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="20dp" android:text="Hack" android:textAllCaps="false" android:textColor="#1A56DB" android:textSize="17sp" android:textStyle="bold" android:backgroundTint="#FFFFFF" app:cornerRadius="28dp" app:strokeColor="#1A56DB" app:strokeWidth="2dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/feedbackTxt"/>

    <Button android:id="@+id/mythBtn" android:layout_width="0dp" android:layout_height="56dp" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="12dp" android:text="Myth" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold" android:backgroundTint="#1A56DB" app:cornerRadius="28dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/hackBtn"/>

    <Button android:id="@+id/nextBtn" android:layout_width="160dp" android:layout_height="50dp" android:layout_marginTop="20dp" android:text="Next" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="16sp" android:backgroundTint="#1A56DB" android:visibility="invisible" app:cornerRadius="25dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/mythBtn"/>
</androidx.constraintlayout.widget.ConstraintLayout>