<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:id="@+id/main" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#EEF3FB" tools:context=".Score">

    <View android:id="@+id/topBar" android:layout_width="0dp" android:layout_height="52dp" android:background="#D6E4F7" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>

    <TextView android:id="@+id/topLabelTxt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Score" android:textColor="#1A56DB" android:textSize="15sp" app:layout_constraintBottom_toBottomOf="@id/topBar" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="@id/topBar"/>

    <TextView android:id="@+id/tvFinalScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="48dp" android:text="Score: 0/7" android:textColor="#1A56DB" android:textSize="32sp" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/topBar"/>

    <androidx.cardview.widget.CardView android:id="@+id/messageCard" android:layout_width="0dp" android:layout_height="160dp" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="24dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvFinalScore">
        <TextView android:id="@+id/tvMessage" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:padding="20dp" android:text="Message" android:textAlignment="center" android:textColor="#6B7C93" android:textSize="16sp" android:lineSpacingExtra="3dp"/>
    </androidx.cardview.widget.CardView>

    <Button android:id="@+id/btnRestart" android:layout_width="0dp" android:layout_height="56dp" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="32dp" android:text="Try Again" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold" android:backgroundTint="#1A56DB" app:cornerRadius="28dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/messageCard"/>

    <Button android:id="@+id/btnExit" android:layout_width="0dp" android:layout_height="56dp" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="12dp" android:text="Exit" android:textAllCaps="false" android:textColor="#1A56DB" android:textSize="17sp" android:textStyle="bold" android:backgroundTint="#FFFFFF" app:cornerRadius="28dp" app:strokeColor="#1A56DB" app:strokeWidth="2dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/btnRestart"/>

    <ImageView android:id="@+id/waveImg" android:layout_width="0dp" android:layout_height="160dp" android:scaleType="fitXY" android:src="@drawable/wave_bg" android:alpha="0.5" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" tools:ignore="ContentDescription"/>
</androidx.constraintlayout.widget.ConstraintLayout>